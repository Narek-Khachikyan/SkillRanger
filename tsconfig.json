{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
}
