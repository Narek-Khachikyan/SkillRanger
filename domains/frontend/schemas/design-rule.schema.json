{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillranger.local/domains/frontend/design-rule.schema.json",
  "type": "object",
  "required": ["schemaVersion", "id", "version", "family", "name", "recipeIds", "preconditions", "intent", "constraints", "rolesConsumed", "responsiveBehavior", "accessibility", "antiPatterns", "verification", "provenance"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "const": "1.0.0" },
    "family": { "enum": ["typography", "layout", "responsive", "color", "state", "signature-move"] },
    "name": { "type": "string", "minLength": 1 },
    "recipeIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "preconditions": { "$ref": "#/$defs/nonEmptyStrings" },
    "intent": { "type": "string", "minLength": 1 },
    "constraints": { "$ref": "#/$defs/nonEmptyStrings" },
    "rolesConsumed": { "$ref": "#/$defs/nonEmptyStrings" },
    "responsiveBehavior": { "$ref": "#/$defs/nonEmptyStrings" },
    "accessibility": { "$ref": "#/$defs/nonEmptyStrings" },
    "antiPatterns": { "$ref": "#/$defs/nonEmptyStrings" },
    "verification": { "$ref": "#/$defs/nonEmptyStrings" },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "reviewedAt"],
        "properties": { "source": { "type": "string", "minLength": 1 }, "reviewedAt": { "type": "string", "format": "date" } },
        "additionalProperties": false
      }
    }
  },
  "$defs": { "nonEmptyStrings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } },
  "additionalProperties": false
}
