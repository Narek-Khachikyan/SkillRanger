{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillranger.local/domains/frontend/design-variant.schema.json",
  "type": "object",
  "required": ["schemaVersion", "id", "recipeId", "directionPath", "ruleIds", "createdOrder", "generatorActorId", "evidenceIds"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "recipeId": { "type": "string", "minLength": 1 },
    "directionPath": { "type": "string", "minLength": 1 },
    "ruleIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "createdOrder": { "type": "integer", "minimum": 0 },
    "generatorActorId": { "type": "string", "minLength": 1 },
    "implementationArtifact": { "type": "string", "minLength": 1 },
    "evidenceIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  },
  "additionalProperties": false
}
