{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillranger.local/domains/frontend/recipe-example.schema.json",
  "type": "object",
  "required": ["schemaVersion", "recipeId", "productScenario", "differenceExplanation", "scenes"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "recipeId": { "type": "string", "minLength": 1 },
    "productScenario": { "type": "string", "minLength": 1 },
    "differenceExplanation": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 1 } },
    "scenes": {
      "type": "array", "minItems": 10, "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["id", "quality", "viewport", "state", "title", "primaryAction", "blocks", "appliedRuleIds", "violatedRuleIds", "asset"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "quality": { "enum": ["good", "bad"] },
          "viewport": { "enum": ["desktop", "mobile"] },
          "state": { "enum": ["success", "loading", "empty", "error"] },
          "title": { "type": "string", "minLength": 1 },
          "primaryAction": { "type": "string", "minLength": 1 },
          "blocks": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/block" } },
          "appliedRuleIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "violatedRuleIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "asset": { "type": "string", "pattern": "^assets/[a-z0-9-]+\\.svg$" }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "block": {
      "type": "object", "required": ["kind", "label", "emphasis"],
      "properties": {
        "kind": { "enum": ["heading", "copy", "action", "list", "media", "status"] },
        "label": { "type": "string", "minLength": 1 },
        "emphasis": { "enum": [1, 2, 3] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
