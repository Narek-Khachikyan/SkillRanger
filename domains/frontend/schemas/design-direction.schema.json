{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillranger.local/domains/frontend/design-direction.schema.json",
  "type": "object",
  "required": ["schemaVersion", "recipeId", "thesis", "productReason", "axes", "typographyRoles", "colorRoles", "signatureMove", "rejectedDefaults", "destructiveCritique"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "recipeId": { "type": "string", "minLength": 1 },
    "thesis": { "type": "string", "minLength": 1 },
    "productReason": { "type": "string", "minLength": 1 },
    "axes": {
      "type": "object",
      "required": ["density", "hierarchy", "composition", "material", "motionIntensity", "expressionLevel"],
      "properties": {
        "density": { "enum": ["compact", "balanced", "spacious", "editorial"] },
        "hierarchy": { "enum": ["action-first", "data-first", "narrative-first", "exception-first"] },
        "composition": { "enum": ["structured-list", "grid", "split-pane", "timeline", "table", "editorial-grid"] },
        "material": { "enum": ["flat", "bordered", "layered", "tactile", "document-like"] },
        "motionIntensity": { "enum": ["none", "low", "medium", "high"] },
        "expressionLevel": { "enum": ["restrained", "balanced", "expressive"] }
      },
      "additionalProperties": false
    },
    "typographyRoles": { "type": "object", "additionalProperties": { "type": "string" } },
    "colorRoles": { "type": "object", "additionalProperties": { "type": "string" } },
    "signatureMove": { "type": "string", "minLength": 1 },
    "rejectedDefaults": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "destructiveCritique": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
