{
  "schemaVersion": "1.0",
  "id": "frontend.design-generation",
  "domain": "frontend",
  "requiredCapabilities": ["filesystem-read", "filesystem-write"],
  "maxRepairIterations": 3,
  "branches": [{
    "id": "critic-decision",
    "afterStepId": "independent-visual-critique",
    "convergeAt": "capture-recheck-evidence",
    "cases": [
      { "id": "rejected", "when": { "criticOutcome": "no-acceptable-variant" }, "stepIds": ["block-no-acceptable-variant"], "terminal": true },
      { "id": "constrained-repair", "when": { "criticOutcome": "selected", "profiles": ["constrained"] }, "stepIds": ["require-selected-variant-or-block-no-acceptable-variant", "repair-requested", "bounded-repair"] },
      { "id": "findings-repair", "when": { "criticOutcome": "selected", "profiles": ["standard", "advanced"], "repairFindings": "positive" }, "stepIds": ["require-selected-variant-or-block-no-acceptable-variant", "repair-requested", "bounded-repair"] },
      { "id": "clean-selection", "when": { "criticOutcome": "selected", "profiles": ["standard", "advanced"], "repairFindings": "zero" }, "stepIds": ["require-selected-variant-or-block-no-acceptable-variant", "no-repair-needed"] }
    ]
  }],
  "steps": [
    { "id": "collect-evidence", "type": "collect", "requires": [], "produces": [".design/brief.json"], "gate": "product-evidence-present" },
    { "id": "validate-brief", "type": "validate", "requires": [".design/brief.json"], "produces": ["brief-findings"] },
    { "id": "resolve-execution-policy", "type": "model", "requires": [".design/brief.json"], "produces": [".design/execution-policy.json"], "gate": "execution-policy-resolved" },
    { "id": "select-recipe", "type": "model", "requires": [".design/brief.json", ".design/execution-policy.json"], "produces": [".design/recipe.json"] },
    { "id": "define-direction", "type": "model", "requires": [".design/brief.json", ".design/execution-policy.json", ".design/recipe.json"], "produces": [".design/direction.json"], "gate": "design-direction-valid" },
    { "id": "validate-direction", "type": "validate", "requires": [".design/direction.json", ".design/execution-policy.json"], "produces": ["direction-findings"], "gate": "design-direction-valid" },
    { "id": "validate-implementation-prerequisites", "type": "validate", "requires": [".design/direction.json", ".design/execution-policy.json"], "produces": ["implementation-prerequisites"], "gate": "implementation-prerequisites-valid" },
    { "id": "implement", "type": "implement", "requires": [".design/direction.json", ".design/execution-policy.json", "implementation-prerequisites"], "produces": ["implementation-diff"] },
    { "id": "capture-initial-evidence", "type": "verify", "requires": ["implementation-diff"], "produces": [".design/initial-evidence.json"], "gate": "responsive-verification" },
    { "id": "independent-visual-critique", "type": "validate", "requires": [".design/direction.json", ".design/initial-evidence.json"], "produces": [".design/visual-critic-report.json"], "gate": "independent-visual-critique-complete" },
    { "id": "require-selected-variant-or-block-no-acceptable-variant", "type": "validate", "requires": [".design/visual-critic-report.json"], "produces": [".design/selected-variant.json"], "gate": "critic-outcome-selected" },
    { "id": "block-no-acceptable-variant", "type": "report", "requires": [".design/visual-critic-report.json"], "produces": [".design/blocked.json"], "gate": "critic-outcome-no-acceptable-variant" },
    { "id": "repair-requested", "type": "validate", "requires": [".design/selected-variant.json", ".design/visual-critic-report.json", ".design/execution-policy.json"], "produces": [".design/repair-request.json"], "gate": "constrained-or-repair-findings" },
    { "id": "bounded-repair", "type": "repair", "requires": [".design/repair-request.json"], "produces": [".design/bounded-repair.json", ".design/accepted-selection.json", "repair-diff"] },
    { "id": "no-repair-needed", "type": "validate", "requires": [".design/selected-variant.json", ".design/visual-critic-report.json", ".design/execution-policy.json"], "produces": [".design/accepted-selection.json"], "gate": "standard-or-advanced-zero-repair-findings" },
    { "id": "capture-recheck-evidence", "type": "verify", "requires": [".design/accepted-selection.json"], "produces": [".design/recheck-evidence.json"], "gate": "fresh-recheck-evidence" },
    { "id": "final-audit", "type": "verify", "requires": [".design/visual-critic-report.json", ".design/recheck-evidence.json"], "produces": [".design/final-audit.json"], "gate": "hard-gates-passed" },
    { "id": "final-verify", "type": "verify", "requires": [".design/final-audit.json"], "produces": [".design/final-verification.json"], "gate": "hard-gates-passed" },
    { "id": "report", "type": "report", "requires": [".design/final-verification.json"], "produces": [".design/DESIGN.md"] }
  ]
}
