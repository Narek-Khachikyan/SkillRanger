{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillranger.local/schemas/router-tool-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok"],
  "properties": {
    "ok": { "type": "boolean" },
    "schemaVersion": { "enum": ["router-result/1.0", "router-read-result/1.0"] },
    "status": { "enum": ["prepared", "clarification_required", "decomposition_required", "no_matching_skills", "strict_requirements_unmet", "context_budget_exceeded"] },
    "activation": { "$ref": "#/$defs/activation" },
    "taskProfile": { "$ref": "#/$defs/taskProfile" },
    "project": { "$ref": "#/$defs/project" },
    "routing": { "$ref": "#/$defs/routing" },
    "warnings": { "$ref": "#/$defs/strings" },
    "run": { "$ref": "#/$defs/run" },
    "selections": { "$ref": "#/$defs/selections" },
    "requiredReads": { "type": "array", "items": { "$ref": "#/$defs/requiredRead" } },
    "runtimeClarification": { "$ref": "#/$defs/runtimeClarification" },
    "verification": { "$ref": "#/$defs/verification" },
    "clarification": { "$ref": "#/$defs/clarification" },
    "continuationToken": { "type": "string", "minLength": 1 },
    "expiresAt": { "type": "string", "format": "date-time" },
    "decomposition": { "$ref": "#/$defs/decomposition" },
    "suggestedAction": { "type": "string", "minLength": 1 },
    "missing": { "type": "array", "items": { "$ref": "#/$defs/missing" } },
    "installationSuggestions": { "type": "array", "items": { "$ref": "#/$defs/installationSuggestion" } },
    "requiredBytes": { "type": "integer", "minimum": 0 },
    "allowedBytes": { "type": "integer", "minimum": 0 },
    "blockingSkillIds": { "$ref": "#/$defs/strings" },
    "routerRunId": { "type": "string", "pattern": "^route_[a-z0-9_-]{7,127}$" },
    "runtimeRunId": { "type": "string", "minLength": 1 },
    "runtime": { "enum": ["lifecycle-v1", "strict-v2"] },
    "readRequestId": { "type": "string", "minLength": 1 },
    "readRevision": { "type": "integer", "minimum": 0 },
    "skillId": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "mimeType": { "enum": ["text/markdown", "text/plain", "application/json"] },
    "content": { "type": "string" },
    "fileChecksum": { "$ref": "#/$defs/digest" },
    "chunkChecksum": { "$ref": "#/$defs/digest" },
    "deliveredOffset": { "type": "integer", "minimum": 0 },
    "deliveredBytes": { "type": "integer", "minimum": 0 },
    "totalBytes": { "type": "integer", "minimum": 0 },
    "complete": { "type": "boolean" },
    "readStatus": { "$ref": "#/$defs/readStatus" },
    "code": { "$ref": "#/$defs/errorCode" },
    "message": { "type": "string", "minLength": 1 },
    "details": { "$ref": "#/$defs/errorDetails" },
    "reasonCode": { "type": "string" },
    "argument": { "type": "string" },
    "explanation": { "$ref": "#/$defs/routerExplanation" }
  },
  "oneOf": [
    { "properties": { "ok": { "const": true }, "schemaVersion": { "const": "router-result/1.0" }, "status": { "const": "prepared" } }, "required": ["schemaVersion", "status", "activation", "taskProfile", "project", "routing", "warnings", "run", "selections", "requiredReads", "verification"] },
    { "properties": { "ok": { "const": true }, "schemaVersion": { "const": "router-result/1.0" }, "status": { "const": "clarification_required" } }, "required": ["schemaVersion", "status", "activation", "taskProfile", "project", "routing", "warnings", "clarification", "continuationToken", "expiresAt"], "not": { "$ref": "#/$defs/preparedFields" } },
    { "properties": { "ok": { "const": true }, "schemaVersion": { "const": "router-result/1.0" }, "status": { "const": "decomposition_required" } }, "required": ["schemaVersion", "status", "activation", "taskProfile", "project", "routing", "warnings", "decomposition"], "not": { "$ref": "#/$defs/preparedFields" } },
    { "properties": { "ok": { "const": true }, "schemaVersion": { "const": "router-result/1.0" }, "status": { "const": "no_matching_skills" } }, "required": ["schemaVersion", "status", "activation", "taskProfile", "project", "routing", "warnings", "suggestedAction"], "not": { "$ref": "#/$defs/preparedFields" } },
    { "properties": { "ok": { "const": true }, "schemaVersion": { "const": "router-result/1.0" }, "status": { "const": "strict_requirements_unmet" } }, "required": ["schemaVersion", "status", "activation", "taskProfile", "project", "routing", "warnings", "missing", "installationSuggestions"], "not": { "$ref": "#/$defs/preparedFields" } },
    { "properties": { "ok": { "const": true }, "schemaVersion": { "const": "router-result/1.0" }, "status": { "const": "context_budget_exceeded" } }, "required": ["schemaVersion", "status", "activation", "taskProfile", "project", "routing", "warnings", "requiredBytes", "allowedBytes", "blockingSkillIds"], "not": { "$ref": "#/$defs/preparedFields" } },
    { "properties": { "ok": { "const": true }, "schemaVersion": { "const": "router-read-result/1.0" } }, "required": ["schemaVersion", "routerRunId", "runtimeRunId", "runtime", "readRequestId", "readRevision", "skillId", "path", "mimeType", "content", "fileChecksum", "chunkChecksum", "deliveredOffset", "deliveredBytes", "totalBytes", "complete", "readStatus"] },
    { "properties": { "ok": { "const": false } }, "required": ["code", "message"] }
  ],
  "$defs": {
    "strings": { "type": "array", "items": { "type": "string" } },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "activation": { "type": "object", "additionalProperties": false, "required": ["mode"], "properties": { "mode": { "enum": ["explicit", "direct"] }, "trigger": { "enum": ["@skillranger", "skillranger", "/sr"] } } },
    "evidence": { "type": "object", "additionalProperties": false, "required": ["source", "kind", "id"], "properties": { "source": { "enum": ["prompt", "fingerprint", "registry", "config"] }, "kind": { "enum": ["action", "artifact", "technology", "quality", "domain", "constraint", "acceptance"] }, "id": { "type": "string" } } },
    "domain": { "type": "object", "additionalProperties": false, "required": ["id", "confidence", "role", "available", "reasons", "evidence"], "properties": { "id": { "type": "string" }, "confidence": { "type": "number", "minimum": 0, "maximum": 1 }, "role": { "enum": ["primary", "supporting"] }, "available": { "type": "boolean" }, "reasons": { "$ref": "#/$defs/strings" }, "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } } } },
    "subtask": { "type": "object", "additionalProperties": false, "required": ["id", "normalizedGoal", "actions", "artifactTypes", "candidateDomainIds"], "properties": { "id": { "type": "string" }, "normalizedGoal": { "type": "string" }, "actions": { "$ref": "#/$defs/strings" }, "artifactTypes": { "$ref": "#/$defs/strings" }, "candidateDomainIds": { "$ref": "#/$defs/strings" } } },
    "taskProfile": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "normalizedGoal", "locale", "actions", "artifactTypes", "technologies", "constraints", "qualityGoals", "acceptanceCriteria", "domains", "subtasks", "evidence"], "properties": { "schemaVersion": { "const": "task-profile/1.0" }, "normalizedGoal": { "type": "string" }, "locale": { "enum": ["en", "ru", "mixed", "unknown"] }, "actions": { "$ref": "#/$defs/strings" }, "artifactTypes": { "$ref": "#/$defs/strings" }, "technologies": { "$ref": "#/$defs/strings" }, "constraints": { "$ref": "#/$defs/strings" }, "qualityGoals": { "$ref": "#/$defs/strings" }, "acceptanceCriteria": { "$ref": "#/$defs/strings" }, "domains": { "type": "array", "items": { "$ref": "#/$defs/domain" } }, "subtasks": { "type": "array", "items": { "$ref": "#/$defs/subtask" } }, "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } } } },
    "project": { "type": "object", "additionalProperties": false, "required": ["displayRoot", "fingerprintDigest", "projectTypes", "languages", "frameworks"], "properties": { "displayRoot": { "type": "string" }, "fingerprintDigest": { "$ref": "#/$defs/digest" }, "projectTypes": { "$ref": "#/$defs/strings" }, "languages": { "$ref": "#/$defs/strings" }, "frameworks": { "$ref": "#/$defs/strings" } } },
    "routing": { "type": "object", "additionalProperties": false, "required": ["targetAgent", "domains", "deterministicKey", "routerAlgorithmVersion", "routingDate", "registryDigest", "configDigest"], "properties": { "targetAgent": { "type": "string" }, "domains": { "type": "array", "items": { "$ref": "#/$defs/domain" } }, "deterministicKey": { "$ref": "#/$defs/digest" }, "routerAlgorithmVersion": { "type": "string" }, "routingDate": { "type": "string", "format": "date" }, "registryDigest": { "$ref": "#/$defs/digest" }, "configDigest": { "$ref": "#/$defs/digest" } } },
    "selection": { "type": "object", "additionalProperties": false, "required": ["skillId", "displayName", "role", "domains", "version", "packageChecksum", "score", "source", "reasons", "verificationStatus"], "properties": { "skillId": { "type": "string" }, "displayName": { "type": "string" }, "role": { "enum": ["environment", "primary", "companion", "verification", "agent-context"] }, "domains": { "$ref": "#/$defs/strings" }, "version": { "type": "string" }, "packageChecksum": { "$ref": "#/$defs/digest" }, "score": { "type": "number", "minimum": 0, "maximum": 1 }, "source": { "enum": ["installed", "bundled-registry", "test-fixture-registry"] }, "reasons": { "$ref": "#/$defs/strings" }, "verificationStatus": { "enum": ["ready", "guidance-only", "not-required"] } } },
    "selections": { "type": "object", "additionalProperties": false, "required": ["environment", "primary", "companions", "verification", "agentContext"], "properties": { "environment": { "type": "array", "items": { "$ref": "#/$defs/selection" } }, "primary": { "$ref": "#/$defs/selection" }, "companions": { "type": "array", "items": { "$ref": "#/$defs/selection" } }, "verification": { "type": "array", "items": { "$ref": "#/$defs/selection" } }, "agentContext": { "type": "array", "items": { "$ref": "#/$defs/selection" } } } },
    "run": { "type": "object", "additionalProperties": false, "required": ["routerRunId", "runtimeRunId", "runtime", "strict", "readRevision"], "properties": { "routerRunId": { "type": "string" }, "runtimeRunId": { "type": "string" }, "runtime": { "enum": ["lifecycle-v1", "strict-v2"] }, "strict": { "type": "boolean" }, "readRevision": { "type": "integer", "minimum": 0 } } },
    "requiredRead": { "type": "object", "additionalProperties": false, "required": ["order", "skillId", "path", "checksum", "bytes", "mandatory"], "properties": { "order": { "type": "integer", "minimum": 0 }, "skillId": { "type": "string" }, "path": { "type": "string" }, "checksum": { "$ref": "#/$defs/digest" }, "bytes": { "type": "integer", "minimum": 0 }, "mandatory": { "const": true } } },
    "runtimeClarification": { "type": "object", "additionalProperties": false, "required": ["questions"], "properties": { "questions": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["id", "fields", "text", "allowDecline"], "properties": { "id": { "type": "string" }, "fields": { "$ref": "#/$defs/strings" }, "text": { "type": "string" }, "allowDecline": { "type": "boolean" } } } } } },
    "verification": { "type": "object", "additionalProperties": false, "required": ["required", "available", "missingCapabilities", "expectedEvidenceKinds"], "properties": { "required": { "type": "boolean" }, "available": { "type": "boolean" }, "missingCapabilities": { "$ref": "#/$defs/strings" }, "expectedEvidenceKinds": { "$ref": "#/$defs/strings" } } },
    "clarificationOption": { "type": "object", "additionalProperties": false, "required": ["value", "label"], "properties": { "value": { "type": "string" }, "label": { "type": "string" } } },
    "clarificationQuestion": { "type": "object", "additionalProperties": false, "required": ["id", "text", "options"], "properties": { "id": { "type": "string" }, "text": { "type": "string" }, "options": { "type": "array", "items": { "$ref": "#/$defs/clarificationOption" } } } },
    "clarification": { "type": "object", "additionalProperties": false, "required": ["questions"], "properties": { "questions": { "type": "array", "items": { "$ref": "#/$defs/clarificationQuestion" } } } },
    "decomposition": { "type": "object", "additionalProperties": false, "required": ["subtasks"], "properties": { "subtasks": { "type": "array", "items": { "$ref": "#/$defs/subtask" } } } },
    "missing": { "type": "object", "additionalProperties": false, "required": ["requirement"], "properties": { "skillId": { "type": "string" }, "requirement": { "enum": ["installed-skill", "lockfile-match", "strict-contract-v2", "skill-input", "capability"] } } },
    "installationSuggestion": { "type": "object", "additionalProperties": false, "required": ["skillId", "reason", "nextTool"], "properties": { "skillId": { "type": "string" }, "reason": { "type": "string" }, "nextTool": { "const": "plan_skill_install" } } },
    "readStatus": { "type": "object", "additionalProperties": false, "required": ["fileComplete", "skillMandatoryReadsComplete", "runMandatoryReadsComplete"], "properties": { "fileComplete": { "type": "boolean" }, "skillMandatoryReadsComplete": { "type": "boolean" }, "runMandatoryReadsComplete": { "type": "boolean" } } },
    "errorCode": { "enum": ["invalid-arguments", "trigger-required", "empty-intent", "intent-too-large", "router-disabled", "target-agent-unresolved", "project-root-unauthorized", "continuation-invalid", "continuation-expired", "clarification-answer-invalid", "skill-not-selected", "skill-source-unavailable", "skill-file-not-found", "skill-path-blocked", "skill-file-unsupported", "stale-skill-checksum", "read-request-conflict", "read-order-invalid", "context-budget-exceeded", "capability-invalid", "router-config-invalid", "raw-intent-confirmation-required", "routing-integrity", "semantic-hint-invalid", "run-not-found", "run-integrity"] },
    "errorDetails": { "type": "object", "additionalProperties": false, "properties": { "reasonCode": { "type": "string" }, "field": { "type": "string" }, "requirement": { "type": "string" }, "argument": { "type": "string" } } },
    "explanationDomain": { "type": "object", "additionalProperties": false, "required": ["id", "score", "reasonCodes"], "properties": { "id": { "type": "string" }, "score": { "type": "number", "minimum": 0, "maximum": 1 }, "reasonCodes": { "$ref": "#/$defs/strings" } } },
    "explanationCandidate": { "type": "object", "additionalProperties": false, "required": ["skillId", "score"], "properties": { "skillId": { "type": "string" }, "score": { "type": "number", "minimum": 0, "maximum": 1 }, "excluded": { "type": "string" } } },
    "explanationOmission": { "type": "object", "additionalProperties": false, "required": ["skillId", "reasonCode"], "properties": { "skillId": { "type": "string" }, "reasonCode": { "type": "string" } } },
    "selectedRoles": { "type": "object", "additionalProperties": false, "required": ["environment", "primary", "companion", "verification", "agent-context"], "properties": { "environment": { "$ref": "#/$defs/strings" }, "primary": { "$ref": "#/$defs/strings" }, "companion": { "$ref": "#/$defs/strings" }, "verification": { "$ref": "#/$defs/strings" }, "agent-context": { "$ref": "#/$defs/strings" } } },
    "routerExplanation": { "type": "object", "additionalProperties": false, "required": ["deterministicKey", "domains", "candidates", "selectedRoles", "omitted"], "properties": { "deterministicKey": { "$ref": "#/$defs/digest" }, "domains": { "type": "array", "items": { "$ref": "#/$defs/explanationDomain" } }, "candidates": { "type": "array", "items": { "$ref": "#/$defs/explanationCandidate" } }, "selectedRoles": { "$ref": "#/$defs/selectedRoles" }, "omitted": { "type": "array", "items": { "$ref": "#/$defs/explanationOmission" } } } },
    "preparedFields": { "anyOf": [{ "required": ["run"] }, { "required": ["selections"] }, { "required": ["requiredReads"] }] }
  }
}
