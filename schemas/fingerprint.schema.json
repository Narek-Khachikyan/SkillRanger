{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillranger.local/schemas/fingerprint.schema.json",
  "type": "object",
  "required": ["schemaVersion", "root", "projectTypes", "languages", "frameworks", "styling", "testing", "agentContext", "signals", "tags", "warnings"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "root": { "type": "string" },
    "packageManager": {
      "type": "object",
      "required": ["name", "confidence", "evidence"],
      "properties": {
        "name": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "projectTypes": { "type": "array" },
    "languages": { "type": "array" },
    "frameworks": { "type": "array" },
    "styling": { "type": "array" },
    "testing": { "type": "array" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "agentContext": { "type": "object" },
    "signals": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
