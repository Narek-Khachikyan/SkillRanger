{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillranger.local/schemas/domain-manifest.schema.json",
  "type": "object",
  "required": ["schemaVersion", "id", "displayName", "version", "coreApi", "skillIdPrefix", "capabilities", "artifacts", "ownership"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": { "$ref": "#/$defs/token" },
    "displayName": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "coreApi": { "type": "string", "minLength": 1 },
    "skillIdPrefix": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*\\.$" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "enum": ["project-signals", "intent-routing", "structured-artifacts", "verification", "repair", "evaluation"] }
    },
    "artifacts": {
      "type": "object",
      "required": ["intents", "schemas", "recipes", "workflows", "validators"],
      "properties": {
        "intents": { "$ref": "#/$defs/paths" },
        "schemas": { "$ref": "#/$defs/paths" },
        "recipes": { "$ref": "#/$defs/paths" },
        "rules": { "$ref": "#/$defs/paths" },
        "examples": { "$ref": "#/$defs/paths" },
        "workflows": { "$ref": "#/$defs/paths" },
        "validators": { "$ref": "#/$defs/paths" },
        "evalSuite": { "type": "string", "minLength": 1 },
        "capabilityRecords": { "$ref": "#/$defs/paths" }
      },
      "additionalProperties": false
    },
    "ownership": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["intent", "primarySkill", "supportingSkills"],
        "properties": {
          "intent": { "$ref": "#/$defs/token" },
          "primarySkill": { "$ref": "#/$defs/token" },
          "supportingSkills": { "$ref": "#/$defs/tags" },
          "requiresEvidence": { "$ref": "#/$defs/tags" }
        },
        "additionalProperties": false
      }
    },
    "routing": {
      "type": "object",
      "required": ["aliases", "intentTags", "artifactTypes", "technologyTags", "projectTags"],
      "properties": {
        "aliases": { "$ref": "#/$defs/tags" },
        "intentTags": { "$ref": "#/$defs/tags" },
        "artifactTypes": { "$ref": "#/$defs/tags" },
        "technologyTags": { "$ref": "#/$defs/tags" },
        "projectTags": { "$ref": "#/$defs/tags" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "token": { "type": "string", "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "tags": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/token" }
    },
    "paths": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    }
  },
  "additionalProperties": false
}
