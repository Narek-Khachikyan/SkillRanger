{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillranger.local/schemas/domain-manifest.schema.json",
  "type": "object",
  "required": ["schemaVersion", "id", "displayName", "version", "coreApi", "skillIdPrefix", "capabilities", "artifacts", "ownership"],
  "properties": {
    "schemaVersion": { "enum": ["1.0", "1.1"] },
    "id": { "$ref": "#/$defs/token" },
    "displayName": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "coreApi": { "type": "string", "minLength": 1 },
    "skillIdPrefix": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*\\.$" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "enum": ["project-signals", "intent-routing", "structured-artifacts", "verification", "repair", "evaluation"] }
    },
    "artifacts": {},
    "ownership": {},
    "routing": { "$ref": "#/$defs/routing" }
  },
  "oneOf": [
    {
      "required": ["schemaVersion", "artifacts", "ownership"],
      "properties": {
        "schemaVersion": { "const": "1.0" },
        "artifacts": { "$ref": "#/$defs/artifactsV10" },
        "ownership": { "$ref": "#/$defs/ownershipV10" }
      }
    },
    {
      "required": ["schemaVersion", "artifacts", "ownership"],
      "properties": {
        "schemaVersion": { "const": "1.1" },
        "artifacts": { "$ref": "#/$defs/artifactsV11" },
        "ownership": { "$ref": "#/$defs/ownershipV11" }
      }
    }
  ],
  "$defs": {
    "token": { "type": "string", "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "tags": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/token" }
    },
    "paths": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },
    "artifactsV10": {
      "type": "object",
      "required": ["intents", "schemas", "recipes", "workflows", "validators"],
      "properties": {
        "intents": { "$ref": "#/$defs/paths" },
        "schemas": { "$ref": "#/$defs/paths" },
        "recipes": { "$ref": "#/$defs/paths" },
        "rules": { "$ref": "#/$defs/paths" },
        "examples": { "$ref": "#/$defs/paths" },
        "workflows": { "$ref": "#/$defs/paths" },
        "validators": { "$ref": "#/$defs/paths" },
        "evalSuite": { "type": "string", "minLength": 1 },
        "capabilityRecords": { "$ref": "#/$defs/paths" }
      },
      "additionalProperties": false
    },
    "artifactsV11": {
      "type": "object",
      "required": ["intents", "schemas", "recipes", "workflows", "validators"],
      "properties": {
        "intents": { "$ref": "#/$defs/paths" },
        "schemas": { "$ref": "#/$defs/paths" },
        "recipes": { "$ref": "#/$defs/paths" },
        "rules": { "$ref": "#/$defs/paths" },
        "examples": { "$ref": "#/$defs/paths" },
        "workflows": { "$ref": "#/$defs/paths" },
        "validators": { "$ref": "#/$defs/paths" },
        "evalSuite": { "type": "string", "minLength": 1 },
        "capabilityRecords": { "$ref": "#/$defs/paths" },
        "routingVocabulary": { "type": "string", "minLength": 1, "maxLength": 256 }
      },
      "additionalProperties": false
    },
    "ownershipV10": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ownershipRuleV10" }
    },
    "ownershipV11": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ownershipRuleV11" }
    },
    "ownershipRuleV10": {
      "type": "object",
      "required": ["intent", "primarySkill", "supportingSkills"],
      "properties": {
        "intent": { "$ref": "#/$defs/token" },
        "primarySkill": { "$ref": "#/$defs/token" },
        "supportingSkills": { "$ref": "#/$defs/tags" },
        "requiresEvidence": { "$ref": "#/$defs/tags" }
      },
      "additionalProperties": false
    },
    "ownershipRuleV11": {
      "type": "object",
      "required": ["intent", "primarySkill", "supportingSkills"],
      "properties": {
        "intent": { "$ref": "#/$defs/token" },
        "primarySkill": { "$ref": "#/$defs/token" },
        "supportingSkills": { "$ref": "#/$defs/tags" },
        "requiresEvidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/requiredEvidence" }
        }
      },
      "additionalProperties": false
    },
    "requiredEvidence": {
      "type": "object",
      "required": ["kind", "id", "allowedSources"],
      "properties": {
        "kind": { "enum": ["domain", "action", "artifact", "intent", "technology", "quality", "constraint", "acceptance"] },
        "id": { "$ref": "#/$defs/token" },
        "allowedSources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["prompt-exact", "prompt-normalized", "prompt-inferred"] }
        }
      },
      "additionalProperties": false
    },
    "routing": {
      "type": "object",
      "required": ["aliases", "intentTags", "artifactTypes", "technologyTags", "projectTags"],
      "properties": {
        "aliases": { "$ref": "#/$defs/tags" },
        "intentTags": { "$ref": "#/$defs/tags" },
        "artifactTypes": { "$ref": "#/$defs/tags" },
        "technologyTags": { "$ref": "#/$defs/tags" },
        "projectTags": { "$ref": "#/$defs/tags" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
