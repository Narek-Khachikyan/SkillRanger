{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillranger.local/schemas/task-profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "normalizedGoal", "locale", "actions", "artifactTypes", "technologies", "constraints", "qualityGoals", "acceptanceCriteria", "domains", "subtasks", "evidence"],
  "properties": {
    "schemaVersion": { "const": "task-profile/1.0" },
    "normalizedGoal": { "type": "string" },
    "locale": { "enum": ["en", "ru", "mixed", "unknown"] },
    "actions": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/action" } },
    "artifactTypes": { "$ref": "#/$defs/canonicalIds" },
    "technologies": { "$ref": "#/$defs/canonicalIds" },
    "constraints": { "$ref": "#/$defs/canonicalIds" },
    "qualityGoals": { "$ref": "#/$defs/canonicalIds" },
    "acceptanceCriteria": { "$ref": "#/$defs/canonicalIds" },
    "domains": { "type": "array", "items": { "$ref": "#/$defs/domain" } },
    "subtasks": { "type": "array", "items": { "$ref": "#/$defs/subtask" } },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
  },
  "$defs": {
    "canonicalId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$" },
    "canonicalIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/canonicalId" } },
    "action": { "enum": ["create", "implement", "modify", "fix", "debug", "review", "test", "verify", "document", "deploy", "migrate", "optimize", "research", "design", "configure", "investigate"] },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "kind", "id"],
      "properties": {
        "source": { "enum": ["prompt", "fingerprint", "registry", "config"] },
        "kind": { "enum": ["action", "artifact", "technology", "quality", "domain", "constraint", "acceptance"] },
        "id": { "$ref": "#/$defs/canonicalId" }
      }
    },
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "confidence", "role", "available", "reasons", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/canonicalId" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "role": { "enum": ["primary", "supporting"] },
        "available": { "type": "boolean" },
        "reasons": { "$ref": "#/$defs/canonicalIds" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      }
    },
    "subtask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "normalizedGoal", "actions", "artifactTypes", "candidateDomainIds"],
      "properties": {
        "id": { "$ref": "#/$defs/canonicalId" },
        "normalizedGoal": { "type": "string" },
        "actions": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/action" } },
        "artifactTypes": { "$ref": "#/$defs/canonicalIds" },
        "candidateDomainIds": { "$ref": "#/$defs/canonicalIds" }
      }
    }
  }
}
