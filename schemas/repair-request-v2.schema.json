{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillranger.local/schemas/repair-request-v2.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "skillId", "iteration", "maxIterations", "gateIds", "sourceReportIndex"],
  "properties": {
    "schemaVersion": { "const": "2.0" },
    "skillId": { "type": "string", "minLength": 1 },
    "iteration": { "type": "integer", "minimum": 1 },
    "maxIterations": { "type": "integer", "minimum": 1, "maximum": 5 },
    "gateIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "sourceReportIndex": { "type": "integer", "minimum": 0 }
  }
}
