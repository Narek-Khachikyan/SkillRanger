{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["implementationOutcome", "verificationState", "artifacts", "changes", "residualRisks"],
  "properties": {
    "implementationOutcome": { "enum": ["implemented", "failed", "blocked"] },
    "verificationState": { "const": "pending-runtime-verification" },
    "artifacts": {
      "type": "object",
      "required": ["brief", "recipe", "direction", "verification"],
      "properties": {
        "brief": { "type": "string" },
        "recipe": { "type": "string" },
        "direction": { "type": "string" },
        "verification": { "type": "string" }
      }
    },
    "changes": { "type": "array", "items": { "type": "string" } },
    "residualRisks": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
