{
  "name": "skillranger",
  "version": "0.2.4",
  "description": "SkillRanger is a local-first router and package manager for AI agent skills.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "skillranger": "dist/cli/index.js",
    "skillranger-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist/",
    "registry/skills/",
    "registry/contracts/",
    "domains/",
    "schemas/",
    "evals/",
    "tests/fixtures/router-cases.json",
    "tests/fixtures/router-packs/",
    "docs/workflow-runtime.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "scan": "node src/cli/index.ts scan",
    "recommend": "node src/cli/index.ts recommend",
    "validate:registry": "node src/cli/index.ts validate:registry",
    "lint:skills": "node src/cli/index.ts lint:skills",
    "audit:registry": "node src/cli/index.ts audit:registry",
    "publish:check": "node src/cli/index.ts publish:check",
    "smoke:package": "node scripts/package-smoke.mjs",
    "release:check": "npm run build && npm run check && npm test && npm run validate:registry && npm run lint:skills && npm run audit:registry && npm run publish:check && npm run eval:frontend -- --run-routing --project fixtures/next-react-ts --json && npm run eval:frontend:ru && npm run eval:router && npm run smoke:package",
    "eval:frontend": "node src/cli/index.ts eval:frontend",
    "eval:frontend:ru": "node src/cli/index.ts eval:frontend --run-routing --project fixtures/next-react-ts --locale ru --json",
    "mcp": "node src/mcp/server.ts",
    "test": "node --test tests/*.test.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "eval:visual": "node src/cli/index.ts eval:visual",
    "eval:router": "node src/evals/router/index.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "agent-skills",
    "skills",
    "mcp",
    "cli",
    "codex",
    "local-first",
    "registry",
    "audit"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
